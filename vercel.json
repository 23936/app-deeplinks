{
  "rewrites": [
    {
      "source": "/.well-known/apple-app-site-association",
      "destination": "/aasa.json"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/aasa.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/product/:id",
      "destination": "https://apps.apple.com/ae/app/twenty-three/id6749473667",
      "statusCode": 302
    },
    {
      "source": "/collection/:id",
      "destination": "https://apps.apple.com/ae/app/twenty-three/id6749473667",
      "statusCode": 302
    }
  ]
}
